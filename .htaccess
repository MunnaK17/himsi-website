# ===============================================================
# HIMSI Website - URL Rewriting & Security
# Untuk Apache (Laragon lokal). Di VPS Nginx pakai nginx-rewrite.conf
# ===============================================================

# Matikan directory listing
Options -Indexes

# Default page kalau folder dibuka tanpa file
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Skip rewrite untuk folder admin/ (admin tetap pakai .php)
    RewriteRule ^admin(/.*)?$ - [L]

    # Internal rewrite: /file -> /file.php
    # (pengunjung lihat URL bersih, server tetap eksekusi .php)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>

# ===============================================================
# Block akses ke file sensitif
# ===============================================================
<FilesMatch "\.(sql|md|log|ini|conf|example)$">
    Require all denied
</FilesMatch>

<Files "robots.txt">
    Require all granted
</Files>
