# ===============================================================
# HIMSI Website - URL Rewriting & Security
# Portable: jalan di local (/himsi-website/) maupun VPS (root /)
# ===============================================================

# Matikan directory listing (folder admin/, uploads/, dll tidak bisa dibrowse)
Options -Indexes

# Default page kalau folder dibuka tanpa file
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ---------------------------------------------------------
    # Skip rewrite untuk folder admin/ (admin tetap pakai .php internal)
    # ---------------------------------------------------------
    RewriteRule ^admin(/.*)?$ - [L]

    # ---------------------------------------------------------
    # 1. Redirect 301: file.php  ->  file (URL bersih untuk publik)
    #    Hanya redirect kalau diakses langsung dari browser (bukan internal)
    # ---------------------------------------------------------
    RewriteCond %{ENV:REDIRECT_STATUS} ^$
    RewriteCond %{THE_REQUEST} \s([^?]*?)\.php[\s?] [NC]
    RewriteRule ^(.+?)\.php$ /%1 [R=301,L,NE]

    # ---------------------------------------------------------
    # 2. Internal rewrite: file  ->  file.php
    #    (pengunjung lihat URL bersih, server tetap eksekusi .php)
    # ---------------------------------------------------------
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>

# ===============================================================
# Block akses ke file sensitif
# ===============================================================
<FilesMatch "\.(sql|md|log|ini|conf)$">
    Require all denied
</FilesMatch>

<Files "robots.txt">
    Require all granted
</Files>
